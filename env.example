# Discord Bot Token (REQUIRED)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Guild ID (optional, for faster command sync)
GUILD_ID=your_guild_id_here

# Channel IDs for auto-posting (optional)
AUTO_CHANNEL_ID=your_auto_channel_id
ROAST_CHANNEL_ID=your_roast_channel_id
VIDEO_CHANNEL_ID=your_video_channel_id
AWARDS_CHANNEL_ID=your_awards_channel_id

# Pro Clubs Tracker Config
CLUB_ID=1427607
PCT_PLATFORM=common-gen5

# Logging
LOG_LEVEL=INFO

# Intervals (hours)
ROAST_COOLDOWN_HOURS=6
AUTO_POST_INTERVAL_HOURS=1
AWARDS_INTERVAL_HOURS=24

# Browser config
BROWSER_HEADLESS=true
BROWSER_RETRIES=3
